import numpy as np

student_scores = np.array([
    [80, 70, 75, 85],
    [60, 65, 70, 75],
    [90, 85, 88, 92],
    [70, 75, 78, 80]
])

avg_scores = student_scores.mean(axis=0)
subjects = ['Math','Science','English','History']
highest = subjects[np.argmax(avg_scores)]

print(avg_scores)
print("Highest Average Subject:", highest)
