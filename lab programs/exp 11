import numpy as np

# Inbuilt Data
fuel_efficiency = np.array([25, 30, 28, 35, 32])

# Average Fuel Efficiency
average_efficiency = np.mean(fuel_efficiency)

# Percentage Improvement (Model A to Model B)
model_A = 25
model_B = 35

percentage_improvement = ((model_B - model_A) / model_A) * 100

print("Average Fuel Efficiency:", average_efficiency)
print("Percentage Improvement:", percentage_improvement, "%")
